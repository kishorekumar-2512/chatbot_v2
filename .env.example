# ── Database ─────────────────────────────────────────────────────────────────────
# Local dev: postgresql://postgres:yourpassword@localhost:5432/intern_db
# AWS RDS:   postgresql://user:pass@your-db.xxxxx.rds.amazonaws.com:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/intern_db

# ── Model priority ───────────────────────────────────────────────────────────────
# Default is "groq" — fast, cheap, no GPU host required. Good default for a
# cloud deployment. Set to "qwen" only if you're also running a GPU-backed
# Ollama host in the same VPC and want it prioritized over the cloud APIs.
# Customer-supplied BYO keys (Settings page) are always tried before this
# chain regardless of what's set here.
PRIMARY_LLM=groq

# ── Primary (default): Groq API ─────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# ── Fallback 1 (default): Google Gemini ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Fallback 2 (default): Qwen via Ollama (local — optional) ────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# CRITICAL: must stay >= 8192, or Ollama silently truncates the prompt at its
# 2048-token default and accuracy degrades without any visible error.
OLLAMA_NUM_CTX=8192

# ── Semantic retrieval (ChromaDB) ────────────────────────────────────────────────
CHROMA_DB_PATH=./embeddings/chroma_store
# Keep at 8 — higher values were the root cause of a real accuracy regression
# (more irrelevant tables + bigger prompt = more truncation risk).
RETRIEVAL_TOP_K=8

# ── Automatic embedding index re-sync ───────────────────────────────────────────
# Hours between automatic incremental re-syncs against the live schema.
# Set to 0 to disable the background scheduler entirely.
REINDEX_INTERVAL_HOURS=24
# Required to use POST /admin/reindex (manual/CI-triggered sync). Leave unset
# to disable that endpoint entirely (returns 503).
ADMIN_API_KEY=

# ── Security ───────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:8501
FRONTEND_ORIGIN_REACT=http://localhost:5173

# ── Streamlit → FastAPI ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Reports ──────────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports

# ── Customer LLM key storage ────────────────────────────────────────────────────
KEY_STORE_PATH=./data/llm_keys.json

# ── Feedback log ─────────────────────────────────────────────────────────────────
FEEDBACK_LOG_PATH=./feedback_log.jsonl

# ── Data source (local vs cloud Postgres) ───────────────────────────────────────
DATA_SOURCE_TYPE=local
DB_SSL_MODE=prefer
DB_POOL_SIZE=10
# CLOUD_DATABASE_URL=postgresql://user:pass@your-rds-instance.region.rds.amazonaws.com:5432/dbname

# ── Authentication (production — leave defaults for local dev) ──────────────────
# Set REQUIRE_AUTH=true for production. When false (default), all routes are open.
REQUIRE_AUTH=false
# JWKS endpoint from your identity provider (AWS Cognito, Auth0, Okta, etc.)
# JWKS_URI=https://cognito-idp.ap-south-1.amazonaws.com/YOUR_POOL_ID/.well-known/jwks.json
# JWT_AUDIENCE=your-app-client-id
# JWT_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/YOUR_POOL_ID

# ── CloudFront (production frontend hosting) ────────────────────────────────────
# Set this to your CloudFront distribution URL so CORS allows it.
# CLOUDFRONT_ORIGIN=https://d1234abcdef.cloudfront.net
